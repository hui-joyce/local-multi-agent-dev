# LangSmith Configuration
# Get your API key from: https://smith.langchain.com
LANGCHAIN_API_KEY=your_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=local-multi-agent-dev

# MLX Model Configuration
# Model: Qwen3.5-9B-MLX-4bit (from mlx-community)
# Source: https://huggingface.co/mlx-community/Qwen3.5-9B-MLX-4bit
# Default is qwen-3.5-9b, can also use qwen-1.5-7b
# MODEL_NAME=qwen-3.5-9b
# MLX_QUANTIZATION=4bit

# Optional: Anthropic API (if needed in future)
# ANTHROPIC_API_KEY=your_anthropic_api_key